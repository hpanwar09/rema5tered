---
import Layout from '../layouts/Layout.astro';
import SideNav from '../components/SideNav.astro';
---

<Layout title="what should i watch?">
  <SideNav />

  <main class="max-w-4xl mx-auto px-6 pt-32 pb-32">
    <div class="space-y-6 text-surface-300 leading-relaxed opacity-0 animate-slide-up" style="animation-delay: 300ms;">
      <p class="text-accent text-fluid-lg font-display">hi, i'm himanshu.</p>
      <p class="text-accent text-fluid-lg font-display">
        i love movies, puzzles, quizzes, trivia, math and coding and i wanted to make something of my own. hope you like
        it!
      </p>

      <p class="text-fluid-base">
        this is a personal project — daily poster puzzles, personalized movie recommendations, and my letterboxd diary,
        all in one place.
      </p>
    </div>

    <div
      class="mt-16 flex items-center justify-center gap-3 opacity-0 animate-slide-up"
      style="animation-delay: 400ms;"
    >
      <a
        href="https://letterboxd.com/REMA5TERED/"
        target="_blank"
        rel="noopener"
        class="font-display text-sm text-surface-400 hover:text-accent transition-colors duration-300">letterboxd</a
      >
      <span class="text-surface-600">|</span>
      <a
        href="mailto:hpanwar442@gmail.com"
        class="font-display text-sm text-surface-400 hover:text-accent transition-colors duration-300">gmail</a
      >
      <span class="text-surface-600">|</span>
      <a
        href="https://github.com/hpanwar09/rema5tered"
        target="_blank"
        rel="noopener"
        class="font-display text-sm text-surface-400 hover:text-accent transition-colors duration-300">github</a
      >
    </div>

    <footer class="mt-48 pt-8 border-t border-surface-800/50 text-center">
      <a href="https://www.themoviedb.org/" target="_blank" rel="noopener">
        <img
          src="https://www.themoviedb.org/assets/2/v4/logos/v2/blue_short-8e7b30f73a4020692ccca9c88bafe5dcb6f8a62a4c6bc55cd9ba82bb2cd95f6c.svg"
          alt="TMDB"
          class="h-5 mx-auto mb-3"
        />
      </a>
      <p class="text-surface-600 text-xs">This product uses the TMDB API but is not endorsed or certified by TMDB.</p>
      <p class="text-surface-700 text-xs mt-1">
        Film data from <a
          href="https://letterboxd.com/"
          class="text-surface-600 hover:text-accent transition-colors duration-300"
          target="_blank"
          rel="noopener">Letterboxd</a
        >
        &amp; <a
          href="https://www.themoviedb.org/"
          class="text-surface-600 hover:text-accent transition-colors duration-300"
          target="_blank"
          rel="noopener">TMDB</a
        >.
      </p>
    </footer>
  </main>
</Layout>
