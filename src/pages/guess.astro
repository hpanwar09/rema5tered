---
import Layout from '../layouts/Layout.astro';
import SideNav from '../components/SideNav.astro';
import GuessTabs from '../components/GuessTabs';

const today = new Date().toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<Layout title="what should i watch?">
  <SideNav />

  <main class="max-w-4xl mx-auto px-6 pt-24 pb-32">
    <header class="mb-12 text-center">
      <p class="text-surface-500 text-sm font-display">{today}</p>
    </header>

    <GuessTabs client:load />
  </main>
</Layout>
